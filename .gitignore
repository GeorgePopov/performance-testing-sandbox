# ====================================================================
# 1. JAVA & MAVEN (Артефакты сборки Spring Boot приложения)
# ====================================================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

### IDE-специфичные файлы (IntelliJ IDEA, Eclipse, NetBeans) ###
.idea/
*.iws
*.iml
*.ipr
/out/
.classpath
.project
.settings/
.metadata/
bin/

### Логи самого приложения ###
*.log
logs/

# ====================================================================
# 2. INFRASTRUCTURE & DATA (Базы данных, очереди, контейнеры)
# ====================================================================
### Базы данных (PostgreSQL локальные данные) ###
# Запрещаем коммитить папки, куда монтируются тома (volumes) контейнеров
pg-data/
postgres-data/
*.db

### Apache Kafka & Zookeeper локальные данные ###
# Игнорируем сохраненные топики, логи брокеров и снапшоты zookeeper
kafka-data/
zookeeper-data/
zookeeper/
kafka/

### Docker хостовые файлы локальной отладки ###
.docker/

# ====================================================================
# 3. PERFORMANCE TESTING (JMeter результаты и отчеты)
# ====================================================================
### JMeter временные файлы и метрики выполнения ###
# Игнорируем логи запусков, файлы результатов (.jtl) и сгенерированные HTML-отчеты
/jmeter/*.log
/jmeter/*.jtl
/jmeter/reports/
/jmeter/report-output/

# ====================================================================
# 4. MONITORING (Grafana & Prometheus локальные данные)
# ====================================================================
### Временные хранилища TSDB (временных рядов) ###
prometheus-data/
grafana-data/
/monitoring/data/

# ====================================================================
# 5. SECURITY & SECRETS (Пароли, доступы, конфиги) — КРИТИЧЕСКИ ВАЖНО
# ====================================================================
# Никогда не отправляем файлы с паролями от БД и токенами в Git
.env
.env.local
*.secret
credentials.json

# Конфигурации локального Kubernetes (если применимо)
kubeconfig
.kube/